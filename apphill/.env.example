# AWS DynamoDB Configuration
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# AWS Region (e.g., ap-south-1, us-east-1)
REACT_APP_AWS_REGION=ap-south-1

# AWS Lambda API Endpoint (optional, if using Backend)
REACT_APP_API_ENDPOINT=https://your-lambda-api.execute-api.ap-south-1.amazonaws.com/dev

# AWS Credentials (for development only, use IAM roles in production)
# DO NOT USE IN PRODUCTION - Use AWS Amplify Studio or Cognito instead
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# AWS S3 Bucket for images/files
REACT_APP_S3_BUCKET=smarthill-bucket

# AWS Cognito (if using authentication)
REACT_APP_AWS_USER_POOL_ID=ap-south-1_xxxxx
REACT_APP_AWS_USER_POOL_WEB_CLIENT_ID=xxxxx

# App Configuration
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_DYNAMODB=true
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_ANALYTICS=true
